                0:	f3 0f 1e fa          	endbr64
                4:	55                   	push   %rbp
                5:	48 89 e5             	mov    %rsp,%rbp
                8:	48 83 ec 10          	sub    $0x10,%rsp
                int y = 15;
                c:	c7 45 fc 0f 00 00 00 	movl   $0xf,-0x4(%rbp)

                if (y &lt; 10) {
                13:	83 7d fc 09          	cmpl   $0x9,-0x4(%rbp)
